# ── Supply-chain hardening ──────────────────────────────────
# Pin exact versions on install (no ^ or ~ drift)
save-exact=true

# Always maintain lockfile
package-lock=true

# ── Note on ignore-scripts ──────────────────────────────────
# We do NOT set ignore-scripts=true globally because esbuild
# and unrs-resolver require postinstall to download platform
# binaries. Vercel CI already uses `npm ci` (deterministic
# from lockfile). If you run `npm install` locally, the
# lockfile prevents version drift.
#
# Packages with postinstall scripts in this repo:
#   esbuild        — downloads platform-specific binary (REQUIRED)
#   unrs-resolver  — native binary postinstall check (REQUIRED)
#   msw            — optional setup script (non-critical)
