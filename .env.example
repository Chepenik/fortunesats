# FortuneSats Environment Variables
# Copy this to .env.local and fill in your values:
#   cp .env.example .env.local

# ── Lightning Payments (MoneyDevKit) ─────────────────────
# Get these from https://moneydevkit.com
MDK_ACCESS_TOKEN=
MDK_MNEMONIC=

# Optional: faster esplora server for LDK chain sync (default: esplora.moneydevkit.com/api)
# MDK_ESPLORA_URL=https://mempool.space/api

# ── Payout Destination ───────────────────────────────────
# Lightning address where MDK sweeps received sats (e.g. user@cash.app)
WITHDRAWAL_DESTINATION=

# ── On-Chain Bitcoin ─────────────────────────────────────
# Your Bitcoin address for receiving on-chain pack payments
BTC_ADDRESS=

# ── Database (Upstash Redis) ─────────────────────────────
# Get these from https://upstash.com (free tier works fine)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Vercel Cron ──────────────────────────────────────────
# Set in Vercel dashboard → Environment Variables (auto-generated on Pro plan)
# CRON_SECRET=

# ── Optional: Tune the Oracle ────────────────────────────
# FS_FORTUNE_PRICE=100       # Sats per fortune (default: 100)
# FS_PACK_PRICE=10000        # Sats per 100-fortune pack (default: 10000)
# FS_PACK_SIZE=100           # Fortunes per pack (default: 100)
# FS_AGENT_API=true          # Enable the agent API (default: true)
# FS_L402=false              # Enable L402 payment gating (default: false)
