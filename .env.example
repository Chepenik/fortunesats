# FortuneSats Environment Variables
# Copy this to .env.local and fill in your values:
#   cp .env.example .env.local

# ── Lightning Payments (Strike) ──────────────────────────
# Create an API key with the following scopes at https://dashboard.strike.me:
#   - partner.invoice.read
#   - partner.invoice.create
#   - partner.invoice.quote.generate
#   - partner.webhooks.manage  (only needed to register webhooks via curl)
STRIKE_API_KEY=
STRIKE_API_BASE_URL=https://api.strike.me/v1

# Signing secret for Strike webhook delivery. You choose this value when you
# create the webhook subscription (POST /v1/subscriptions). 48 hex chars is a
# safe default: `openssl rand -hex 24`. Must be ≤ 50 characters.
STRIKE_WEBHOOK_SECRET=

# ── On-Chain Bitcoin ─────────────────────────────────────
# Your Bitcoin address for receiving on-chain pack payments
BTC_ADDRESS=

# ── Database (Upstash Redis) ─────────────────────────────
# Get these from https://upstash.com (free tier works fine)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Vercel Cron ──────────────────────────────────────────
# Set in Vercel dashboard → Environment Variables (auto-generated on Pro plan)
# CRON_SECRET=

# ── Optional: Tune the Oracle ────────────────────────────
# FS_FORTUNE_PRICE=100       # Sats per fortune (default: 100)
# FS_PACK_PRICE=10000        # Sats per 100-fortune pack (default: 10000)
# FS_PACK_SIZE=100           # Fortunes per pack (default: 100)
# FS_AGENT_API=true          # Enable the agent API (default: true)
